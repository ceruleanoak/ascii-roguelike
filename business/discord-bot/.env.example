# Copy to .env on the Mac mini and fill in. Never commit the real .env.

# Bot token from the Discord Developer Portal (Bot > Reset Token).
DISCORD_BOT_TOKEN=

# The CeruleanOak server (guild) ID. Right-click the server icon > Copy Server ID
# (requires Developer Mode on in Discord settings).
GUILD_ID=

# Optional: comma-separated channel IDs to collect from. Leave blank = all text
# channels the bot can read.
CHANNEL_ALLOWLIST=

# Optional: comma-separated channel IDs to never collect from (e.g. mod-only).
CHANNEL_DENYLIST=

# Where the JSON store lives on disk. Defaults to ./data next to the bot.
DATA_DIR=./data

# Store full message text (true) or only metadata + classification (false).
# The community-heartbeat job needs text to draft replies, so default is true.
# Set false if you want a leaner, more privacy-conservative log.
STORE_CONTENT=true

# How many days of history backfill should reach for (per channel). 0 = unlimited.
BACKFILL_DAYS=90
